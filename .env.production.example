# Скопируй этот файл в .env.production на сервере и заполни значения.
# Берутся из текущего .env в Lovable (Cloud → Backend).

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Серверные значения нужны для отправки заявок через server functions.
# Обычно они такие же, как VITE_* выше.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=  # только если реально нужен
